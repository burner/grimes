    "url": "git+https://github.com/burner/grimes.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "AGPL-3.0",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.30",
    "@opencode-ai/sdk": "^1.14.30"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "eslint": "^9",
    "eslint-plugin-unicorn": "^57",
    "jiti": "^2.6.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8"
  },
  "scripts": {
    "build": "bun build grimes.ts --outdir=dist --target=bun",
